{
  "routes": [
    {
      "route": "/creator.html",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/creator",
      "rewrite": "/creator.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/*.{css,js,png,jpg,gif,ico,svg,woff,woff2,json}"]
  },
  "globalHeaders": {
    "Cache-Control": "no-store",
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY"
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
